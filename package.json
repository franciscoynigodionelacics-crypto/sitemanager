{
  "name": "sitemanager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"magenta,blue\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build:frontend": "cd apps/frontend && npm run build",
    "build:backend": "cd backend && npx tsc"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ]
}
